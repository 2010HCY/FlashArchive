<!DOCTYPE html>
<html lang="zh">
<%- include('head', { pageType: 'game' }) %>
<body>
    <%- include('header') %>
    <main class="main-content">
        <div class="game-container">
            <div id="gameEmbed" style="width:100%;height:100%;"></div>
        </div>
        <div class="text-container">
            <h1>
                <%= game.title %>
            </h1>
            <div class="switch-buttons" id="gameVerSwitchBox">
                <div class="ver-dropdown-wrapper">
                    <button id="gameVerDropdownBtn" class="ver-dropdown-btn">
                        版本切换 - <span id="curVerName"><%= game.files[0].name %></span>
                        <i class="fas fa-chevron-down dropdown-icon"></i>
                    </button>
                    <div id="gameVerDropdown" class="ver-dropdown-menu" style="display:none;">
                        <% if (game.files.length === 1) { %>
                        <div class="ver-dropdown-item disabled">无更多版本</div>
                        <% } else { %>
                        <% game.files.forEach((file, index)=> { -%>
                        <div class="ver-dropdown-item" id="verItem<%= index %>" data-index="<%= index %>" onclick="switchGame(<%= index %>);toggleVerDropdown(false)">
                            <%= file.name %>
                        </div>
                        <% }) %>
                        <% } %>
                    </div>
                </div>
                <button id="downloadBtn" class="tool-btn" data-tooltip="下载"><i class="fas fa-download"></i></button>
                <button id="simple-keyboard-btn" class="tool-btn" data-tooltip="屏幕键盘"><i class="fas fa-keyboard"></i></button>
                <button id="fullscreen-btn" class="tool-btn" data-tooltip="全屏畅玩"><i class="fas fa-expand"></i></button>
            </div>
            <h2>如何游玩</h2>
            <p><%- game.play %></p>
            <p>你可以按上面的按钮切换不同版本</p>
            <div id="zan" class="clearfix">
                <div class="heart" onclick="goodplus(url, flag)"></div>
                <br>
                <div id="zan_text"></div>
            </div>
        </div>
    </main>
    <section class="text" aria-labelledby="desc-title">
        <h2 id="desc-title">说明</h2>
        <div class="stats">
            <span class="stat-item">
                <i class="far fa-eye fa-fw"></i>总计游玩次数:
                <span class="stats-value" id="PageMeter_page_pv">加载中...</span>
            </span>
            <span class="stat-item">
                <i class="fas fa-users fa-fw"></i>
                <span class="stat-label">作者:</span>
                <% if (author.link) { %>
                    <a href="<%= author.link %>"><%= author.text %></a>
                <% } else { %>
                    <span><%= author.text %></span>
                <% } %>
            </span>
            <% if (translators && translators.length) { %>
                <span class="stat-item">
                    <i class="fas fa-language fa-fw"></i>
                    <span class="stat-label">汉化者:</span>
                    <% translators.forEach(function(t, idx) { %>
                        <a href="<%= t.link %>"><%= t.text %></a><%= idx < translators.length - 1 ? ', ' : '' %>
                    <% }) %>
                </span>
            <% } %>
            <span class="stat-item">
                <i class="far fa-calendar-alt fa-fw"></i>
                <span class="<%= pubTime.valid ? '' : 'time-invalid' %>">
                    <%= pubTime.text %>
                </span>
            </span>
        </div>
        <div class="description-container">
            <div class="desc-image-box">
                <img src="<%= game.cover %>" alt="<%= game.title %>">
            </div>
            <div class="desc-text-box">
                <p><strong>游戏名称：</strong><%= game.title %></p>
                <p><strong>兼容引擎：</strong><a target="_blank" rel="noopener" href="https://ruffle.rs/">Ruffle</a>, Adobe Flash Player</p>
                <p><strong>收录版本：</strong><%= versionKeywords.join(' / ') %></p>
                <p><strong>文件大小：</strong><% if (fileSizes && fileSizes.length) { %><%= fileSizes.map(s => s.value + s.unit).join(' / ') %><% } %></p>
                <p>觉得好玩的话就点个赞吧</p>
            </div>
        </div>
    </section>
    <section id="twikoo" aria-label="评论区">
        <%- include('twikoo') %>
    </section>
    <script>
        let player;
        let rufflePlayer;

        window.RufflePlayer = window.RufflePlayer || {};
        window.RufflePlayer.config = {
            "letterbox": "on",
            "scale": "showAll",
            "forceScale": true,
            "autoplay": "on",
            "unmuteOverlay": "hidden"
        };

        document.addEventListener('DOMContentLoaded', function () {
            rufflePlayer = window.RufflePlayer.newest();

            player = rufflePlayer.createPlayer();

            const container = document.getElementById('gameEmbed');
            if (container) {
                container.appendChild(player);
            }

            if (typeof switchGame === "function") {
                switchGame(0);
            }
            
            const firstItem = document.getElementById('verItem0');
            if (firstItem) {
                firstItem.classList.add('active');
            }
        });
    </script>
    <script>
        // 切换游戏版本
        const gameFiles = <%- JSON.stringify(game.files) %>;
        let curGameIndex = 0;
        function switchGame(index) {
            if (!player) return;
            const file = gameFiles[index];
            if (!file) return;
            curGameIndex = index;
            player.load({
                url: file.path,
                base: file.base || file.path.substring(0, file.path.lastIndexOf('/') + 1)
            });
            const nameEl = document.getElementById('curVerName');
            if (nameEl) nameEl.textContent = file.name;
            
            // 更新下拉菜单选中状态
            document.querySelectorAll('.ver-dropdown-item').forEach((item, idx) => {
                if (idx == index) {
                    item.classList.add('active');
                } else {
                    item.classList.remove('active');
                }
            });
        }
    </script>
    <script>
        // 切换版本下拉菜单
        function toggleVerDropdown(show) {
            var dropdown = document.getElementById('gameVerDropdown');
            var btn = document.getElementById('gameVerDropdownBtn');
            if (!dropdown) return;

            dropdown.style.display = show ? 'block' : 'none';

            if (show) {
                btn.classList.add('active');
            } else {
                btn.classList.remove('active');
            }
        }
        document.addEventListener('DOMContentLoaded', function () {
            var btn = document.getElementById('gameVerDropdownBtn');
            var menu = document.getElementById('gameVerDropdown');
            if (btn && menu) {
                btn.onclick = function (e) {
                    e.stopPropagation();
                    toggleVerDropdown(menu.style.display !== 'block');
                }
                document.body.addEventListener('click', function () { toggleVerDropdown(false); });
                menu.onclick = function (e) { e.stopPropagation(); }
            }
        });
    </script>
    <script src="/api/play/simple-keyboard.js"></script>
    <script>
        // 屏幕键盘全屏功能
        window.keyboardContainer = window.keyboardContainer || null;
        window.activeKeys = new Set();

        function toggleKeyboard() {
            const body = document.body;

            if (!window.keyboardContainer) {
                // 创建键盘容器
                window.keyboardContainer = document.createElement('div');
                window.keyboardContainer.id = 'simple-keyboard-container';
                window.keyboardContainer.className = 'simple-keyboard hg-theme-default';
                document.body.appendChild(window.keyboardContainer);

                // 初始化键盘库
                const KBClass = window.SimpleKeyboard.default || window.SimpleKeyboard;
                new KBClass(".simple-keyboard", {
                    onRender: () => {
                        document.querySelectorAll('.hg-button').forEach(button => {
                            const btnAttr = button.getAttribute('data-skbtn');
                            button.onpointerdown = (e) => { e.preventDefault(); handleKeyAction(btnAttr, 'down'); };
                            button.onpointerup = (e) => { e.preventDefault(); handleKeyAction(btnAttr, 'up'); };
                            button.onpointerleave = (e) => { handleKeyAction(btnAttr, 'up'); };
                        });
                    },
                    layout: {
                        'default': [
                            '1 2 3 4 5 6 7 8 9 0', 'Q W E R T Y U I O P', 'A S D F G H J K L',
                            '{shiftalt} Z X C V B N M {bksp}', 'Fn Ctrl Alt {arrowup} Enter',
                            '{exit} {space} {arrowleft} {arrowdown} {arrowright}'
                        ]
                    },
                    display: {
                        '{bksp}': '⌫', '{enter}': 'Enter', '{shiftalt}': '⇧', '{exit}': 'Exit',
                        '{space}': '␣', '{arrowup}': '↑', '{arrowleft}': '←', '{arrowdown}': '↓', '{arrowright}': '→'
                    }
                });
            }

            // 切换显示/隐藏
            const isOpening = window.keyboardContainer.style.display === 'none' || !document.body.classList.contains('is-theater-mode');
            const gameEmbed = document.getElementById('gameEmbed');

            if (isOpening) {
                document.body.classList.add('is-theater-mode');
                window.keyboardContainer.style.display = 'block';
                gameEmbed.style.cssText = 'width: 100%; flex: 1;';
                ensureExitBtn();
            } else {
                document.body.classList.remove('is-theater-mode');
                window.keyboardContainer.style.display = 'none';
                gameEmbed.style.cssText = 'width: 100%; height: 100%;';
            }
            window.dispatchEvent(new Event('resize'));
        }

        function handleKeyAction(button, type) {
            if (button === '{exit}' && type === 'down') {
                toggleKeyboard();
                return;
            }

            const keyMap = {
                '{bksp}': { k: 'Backspace', c: 'Backspace', v: 8 },
                '{enter}': { k: 'Enter', c: 'Enter', v: 13 },
                '{shiftalt}': { k: 'Shift', c: 'ShiftLeft', v: 16 },
                'Ctrl': { k: 'Control', c: 'ControlLeft', v: 17 },
                'Alt': { k: 'Alt', c: 'AltLeft', v: 18 },
                '{space}': { k: ' ', c: 'Space', v: 32 },
                '{arrowup}': { k: 'ArrowUp', c: 'ArrowUp', v: 38 },
                '{arrowdown}': { k: 'ArrowDown', c: 'ArrowDown', v: 40 },
                '{arrowleft}': { k: 'ArrowLeft', c: 'ArrowLeft', v: 37 },
                '{arrowright}': { k: 'ArrowRight', c: 'ArrowRight', v: 39 }
            };

            const eventData = keyMap[button] || { k: button, c: 'Key' + button.toUpperCase(), v: button.toUpperCase().charCodeAt(0) };
            const target = document.querySelector('#gameEmbed canvas') || document.querySelector('#gameEmbed').firstChild;

            if (!target) return;

            if (type === 'down') {
                if (window.activeKeys.has(button)) return;
                window.activeKeys.add(button);
                target.focus();
                target.dispatchEvent(new KeyboardEvent('keydown', {
                    key: eventData.k, code: eventData.c, keyCode: eventData.v, which: eventData.v, bubbles: true
                }));
            } else {
                if (!window.activeKeys.has(button)) return;
                window.activeKeys.delete(button);
                target.dispatchEvent(new KeyboardEvent('keyup', {
                    key: eventData.k, code: eventData.c, keyCode: eventData.v, which: eventData.v, bubbles: true
                }));
            }
        }
    </script>
    <script>
        // 纯全屏功能
        function enterPureFull() {
            const body = document.body;
            const gameEmbed = document.getElementById('gameEmbed');
            
            body.classList.add('is-pure-fullscreen');
            gameEmbed.style.cssText = 'position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; z-index: 9998;';
            ensureExitBtn();
            window.dispatchEvent(new Event('resize'));

            const preventEsc = (e) => {
                if (e.key === 'Escape' && body.classList.contains('is-pure-fullscreen')) {
                    e.preventDefault();
                    e.stopImmediatePropagation();
                    console.log("若要退出全屏，请点击右下角按钮退出全屏");
                }
            };
            window.addEventListener('keydown', preventEsc, true);
        }
    </script>
    <script>
        // 通用退出按钮
        function ensureExitBtn() {
            let btn = document.getElementById('exit-fullscreen-btn');
            if (!btn) {
                btn = document.createElement('div');
                btn.id = 'exit-fullscreen-btn';
                btn.innerHTML = '<i class="fas fa-compress"></i>';
                btn.onclick = () => {
                    document.body.classList.remove('is-theater-mode', 'is-pure-fullscreen');
                    if (window.keyboardContainer) window.keyboardContainer.style.display = 'none';
                    document.getElementById('gameEmbed').style.cssText = 'width: 100%; height: 100%;';
                    window.dispatchEvent(new Event('resize'));
                };
            }
            const gameContainer = document.querySelector('.game-container');
            if (gameContainer) {
                gameContainer.appendChild(btn); 
            } else {
                document.body.appendChild(btn);
            }
        }

        // 初始化：绑定屏幕键盘按钮
        document.addEventListener('DOMContentLoaded', function () {
            const keyboardBtn = document.getElementById('simple-keyboard-btn');
            if (keyboardBtn) {
                keyboardBtn.addEventListener('click', toggleKeyboard);
            }
            const fullscreenBtn = document.getElementById('fullscreen-btn');
            if (fullscreenBtn) {
                fullscreenBtn.addEventListener('click', enterPureFull);
            }
        });
    </script>

    <script>
        // 下载模态框
        function toggleDownloadModal(show) {
            const md = document.getElementById('downloadModal');
            if (md) {
                md.style.display = show ? 'flex' : 'none';
            }
        }

        document.addEventListener('DOMContentLoaded', function () {
            const btn = document.getElementById('downloadBtn');
            if (btn) {
                btn.onclick = function () {
                    toggleDownloadModal(true);
                };
            }
            const modal = document.getElementById('downloadModal');
            if (modal) {
                modal.onclick = function () {
                    toggleDownloadModal(false);
                };
            }
            const panel = document.querySelector('.download-modal-panel');
            if (panel) {
                panel.onclick = function (e) {
                    e.stopPropagation();
                };
            }
        });
    </script>
    <div id="downloadModal" class="download-modal" style="display:none;">
        <div class="download-modal-mask"></div>
        <div class="download-modal-panel">
            <i class="fas fa-times modal-close" onclick="toggleDownloadModal(false)"></i>
            <div class="modal-title">下载</div>
            <div class="modal-download-list">
                <% game.DownFiles.forEach(function(file, idx) { %>
                    <div class="modal-download-entry">
                        <a href="<%= file.path %>" download="<%= file.name %>" title="<%= file.name %>">
                            <i class="fa-solid fa-file-arrow-down" style="margin-right:8px; color: #00a4ef;"></i><%= file.name %>
                        </a>
                    </div>
                    <% if (idx !==game.DownFiles.length - 1) { %>
                        <div class="modal-divider"></div>
                    <% } %>
                <% }) %>
                <div class="modal-divider"></div>
                <div class="modal-download-entry player-entry">
                    <a href="/Falsh播放器.exe" download="Falsh播放器.exe">
                        <i class="fab fa-windows" style="margin-right:8px; color: #00a4ef;"></i>Flash 播放器
                    </a>
                </div>
            </div>
        </div>
    </div>
    <%- include('footer') %>
    <%- include('search') %>
</body>
</html>
