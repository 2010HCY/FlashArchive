<!DOCTYPE html>
<html lang="zh">
<%- include('head', { pageType: 'game' }) %>
<body>
    <%- include('header') %>
    <main class="main-content">
        <div class="game-container">
            <div id="gameEmbed" style="width:100%;height:100%;"></div>
        </div>
        <div class="text-container">
            <h1>
                <%= game.title %>
            </h1>
            <div class="switch-buttons" id="gameVerSwitchBox">
                <% if (game.files.length <=3) { %>
                <% game.files.forEach((file, index)=> { -%>
                    <button onclick="switchGame('<%= index %>')"><%= file.name %></button>
                <% }) %>
                <% } else { %>
                    <button id="gameVerDropdownBtn">切换版本 (<span id="curVerName"><%= game.files[0].name %></span>) <i class="fas fa-chevron-down dropdown-icon"></i></button>
                        <div id="gameVerDropdown" class="ver-dropdown-menu" style="display:none;">
                            <% game.files.forEach((file, index)=> { -%>
                            <div class="ver-dropdown-item" id="verItem<%= index %>" onclick="switchGame('<%= index %>');toggleVerDropdown(false)">
                                <%= file.name %><i class="fas fa-check ver-check" style="display:none; margin-right:8px;"></i>
                            </div>
                            <% }) %>
                    </div>
                <% } %>
                <button id="downloadBtn" class="bottomP">下载</button>
            </div>
            <br>
            <i class="far fa-eye fa-fw"></i>总计游玩次数:&nbsp;&nbsp;
            <span class="stats-value" id="PageMeter_page_pv">加载中...</span>
            <h2>如何游玩</h2>
            <p><%- game.play %></p>
            <p>你可以按上面的按钮切换不同版本</p>
            <div id="zan" class="clearfix">
                <div class="heart" onclick="goodplus(url, flag)"></div>
                <br>
                <div id="zan_text"></div>
            </div>
        </div>
    </main>
    <section class="text" aria-labelledby="desc-title">
    <h2 id="desc-title">说明</h2>
        <p>这是flash游戏，2025年了，支持flash的浏览器一个巴掌也数的过来，我已经在网站上部署了Ruffle，如果还是无法游玩，试试以下方法</p>
        <p>安装插件，安装这个叫<a target="_blank" rel="noopener" href="https://ruffle.rs/">Ruffle</a>的浏览器插件就好了<a target="_blank" rel="noopener" href="https://microsoftedge.microsoft.com/addons/detail/ruffle-flash-emulator/pipjjbgofgieknlpefmcckdmgaaegban">点击跳转</a></p>
        <p>下载游戏，然后将swf游戏文件用flash播放器打开</p>
        <p>Ruffle的兼容性不是很好，已知一些3D游戏无法游玩，并且有可能会出现按钮失灵、文字贴图不显示，所以我强烈建议下载下来以获得最佳体验</p>
        <p>评论区在下面，你们遇到问题可以反馈给我，但大概率我也只能建议你们下载到本地游玩...Flash的兼容性安全性真是太差了</p>
    </section>
    <section id="twikoo" aria-label="评论区">
        <div id="tcomment"></div>
        <script src="/api/play/twikoo.min.js"></script>
        <script>
            twikoo.init({
            envId: 'https://twikoo.hcyhub.com/.netlify/functions/twikoo',
            el: '#tcomment',
            lang: 'zh-CN',
            })
        </script>
    </section>
    <script>
        // 初始化 Ruffle 播放器
        document.addEventListener('DOMContentLoaded', function () {
            window.RufflePlayer = window.RufflePlayer || {};
            rufflePlayer = window.RufflePlayer.newest();

            player = rufflePlayer.createPlayer({
                allowScriptAccess: true,
                scale: "showall",
                forceScale: true,
                autoplay: "on",
                backgroundColor: null,
                polyfills: true,
                allowNetworking: "internal",
            });

            const container = document.getElementById('gameEmbed');
            container.appendChild(player);

            switchGame(0);
        });
    </script>
    <script>
        // 切换游戏版本
        const gameFiles = <%- JSON.stringify(game.files) %>;
        let curGameIndex = 0;
        function switchGame(index) {
            if (!player) return;
            const file = gameFiles[index];
            if (!file) return;
            curGameIndex = index;
            player.load({
                url: file.path,
                base: file.base || file.path.substring(0, file.path.lastIndexOf('/') + 1)
            });
            const nameEl = document.getElementById('curVerName');
            if (nameEl) nameEl.textContent = file.name;
        }
    </script>
    <script>
        // 切换版本下拉菜单
        function toggleVerDropdown(show) {
            var dropdown = document.getElementById('gameVerDropdown');
            var btn = document.getElementById('gameVerDropdownBtn');
            if (!dropdown) return;

            dropdown.style.display = show ? 'block' : 'none';

            if (show) {
                btn.classList.add('ver-dropdown-open');
            } else {
                btn.classList.remove('ver-dropdown-open');
            }
        }
        document.addEventListener('DOMContentLoaded', function () {
            var btn = document.getElementById('gameVerDropdownBtn');
            var menu = document.getElementById('gameVerDropdown');
            if (btn && menu) {
                btn.onclick = function (e) {
                    e.stopPropagation();
                    toggleVerDropdown(menu.style.display !== 'block');
                }
                document.body.addEventListener('click', function () { toggleVerDropdown(false); });
                menu.onclick = function (e) { e.stopPropagation(); }
            }
        });
    </script>
    <script>
        // 下载模态框
        function toggleDownloadModal(show) {
            var md = document.getElementById('downloadModal');
            if (md) {
                md.style.display = show ? 'flex' : 'none';
            }
        }

        document.addEventListener('DOMContentLoaded', function () {
            var btn = document.getElementById('downloadBtn');
            if (btn) {
                btn.onclick = function () {
                    toggleDownloadModal(true);
                }
            }
            var modal = document.getElementById('downloadModal');
            if (modal) modal.onclick = function () {
                toggleDownloadModal(false);
            };
            var panel = document.querySelector('.download-modal-panel');
            if (panel) panel.onclick = function (e) {
                e.stopPropagation();
            }
        });
    </script>
    <div id="downloadModal" class="download-modal" style="display:none;">
        <div class="download-modal-mask"></div>
        <div class="download-modal-panel">
            <i class="fas fa-times modal-close" onclick="toggleDownloadModal(false)"></i>
            <div class="modal-title">下载</div>
            <div class="modal-download-list">
                <% game.DownFiles.forEach(function(file, idx) { %>
                    <div class="modal-download-entry">
                        <a href="<%= file.path %>" download="<%= file.name %>" title="<%= file.name %>">
                            <i class="fa-solid fa-file-arrow-down" style="margin-right:8px; color: #00a4ef;"></i><%= file.name %>
                        </a>
                    </div>
                    <% if (idx !==game.DownFiles.length - 1) { %>
                        <div class="modal-divider"></div>
                    <% } %>
                <% }) %>
                <div class="modal-divider"></div>
                <div class="modal-download-entry player-entry">
                    <a href="/Falsh播放器.exe" download="Falsh播放器.exe">
                        <i class="fab fa-windows" style="margin-right:8px; color: #00a4ef;"></i>Flash 播放器
                    </a>
                </div>
            </div>
        </div>
    </div>
    <%- include('footer') %>
    <%- include('search') %>
</body>
</html>
