<head>
    <meta charset="UTF-8">
    
    <% if (pageType === 'home') { %>
        <% let currentUrl = "https://" + domain + "/";if (typeof currentPage !== 'undefined' && currentPage > 1) {currentUrl += currentPage } %>
        <title>静水深流 | Flash收藏站</title>
        <meta name="keywords" content="静水深流,Flash游戏收藏站,Flash收藏站,在线小游戏,Flash游戏,Flash游戏汉化版">
        <meta name="description" content="欢迎来到我的个人Flash收藏空间！所以游戏都是人工汉化，支持一键切换原版和汉化版，你也可以直接下载喜欢的游戏。部分游戏还附有攻略，希望你玩得高兴！">
        <link rel="stylesheet" href="/api/index/index.css">
        <meta property="og:type" content="website">
        <meta property="og:title" content="静水深流 | Flash收藏站">
        <meta property="og:description" content="Flash收藏站，收集大量好玩的Flash游戏，支持在线游玩和下载。">
        <meta property="og:image" content="https://<%= domain %>/api/icon/H.svg">
    <% } else if (pageType === 'game' && typeof game !== 'undefined') { %>
        <title><%= game.title %></title>
        <meta name="keywords" content="静水深流,Flash游戏收藏站,在线小游戏,Flash游戏,Flash游戏汉化版,<%= game.title %><% if (typeof versionKeywords !== 'undefined' && versionKeywords.length > 0) { %>,<%= versionKeywords.join(',') %><% } %>">
        <meta name="description" content="<%= game.brief %>">
        <link rel="stylesheet" href="/api/play/play.css">
        <link rel="stylesheet" href="/api/play/simple-keyboard.css">
        <script src="/api/ruffle/ruffle.js" defer></script>
        <script src="/api/play/zan.js" defer></script>
        <meta property="og:type" content="website">
        <meta property="og:title" content="<%= game.title %>">
        <meta property="og:description" content="<%= game.brief %>">
        <meta property="og:image" content="https://<%= domain + game.cover %>">
    <% } else if (pageType === 'post' && typeof game !== 'undefined') { %>
        <title><%= game.title %></title>
        <meta name="keywords" content="静水深流,Flash游戏收藏站,在线小游戏,Flash游戏,文章,<%= game.title %>">
        <meta name="description" content="<%= game.brief %>">
        <link rel="stylesheet" href="/api/post/post.css">
        <meta property="og:type" content="article">
        <meta property="og:title" content="<%= game.title %>">
        <meta property="og:description" content="<%= game.brief %>">
        <meta property="og:image" content="https://<%= domain + game.cover %>">

    <% } else if (pageType === '404' ) { %>
        <title>404 Not Found</title>
        <meta name="description" content="页面不存在">
    <% } else if (pageType === 'about') { %>
        <title>关于 | Flash收藏站</title>
        <meta name="description" content="关于本站的统计信息与介绍">
        <link rel="stylesheet" href="/api/common/about.css">
    <% } else if (pageType === 'author-games') { %>
        <% 
            var dynamicKeywords = ""; 
            var dynamicTitle = "";
            var dynamicDesc = "";
            if (personType === 'author') { 
                dynamicTitle = personName + " 所有的作品"; 
                dynamicDesc = "此为 " + personName + " 被收藏的所有作品"; 
                dynamicKeywords = personName + "开发的Flash游戏, "; 
            } else { 
                dynamicTitle = personName + " 汉化的游戏"; 
                dynamicDesc = "此为 " + personName + " 汉化的游戏"; 
                dynamicKeywords = personName + "汉化的Flash游戏, "; 
            } 
        %>
        <title><%= dynamicTitle %> | Flash收藏站</title>
        <meta name="keywords" content="<%= dynamicKeywords %><%= personName %>,Flash游戏收藏站,Flash收藏站,在线小游戏,Flash游戏">
        <meta name="description" content="<%= dynamicDesc %>。部分游戏还附有攻略，希望你玩得高兴！">
        <meta property="og:type" content="website">
        <meta property="og:title" content="<%= dynamicTitle %> | Flash收藏站">
        <meta property="og:description" content="<%= dynamicDesc %>">
        <meta property="og:image" content="https://<%= domain %>/api/icon/H.svg">
        <link rel="stylesheet" href="/api/common/author-games.css"> 
    <% } else if (pageType === 'authors' || pageType === 'translators' || pageType === 'author') { %>
        <title><%= title %> | Flash收藏站</title>
        <link rel="stylesheet" href="/api/common/author.css">
    <% } else if (pageType==='friend' ) { %>
        <title>友链 | Flash收藏站</title>
        <meta name="description" content="友情链接，欢迎交换友链！">
        <link rel="stylesheet" href="/api/common/friend.css"> 
        <script src="/api/play/zan.js" defer></script>
    <% } else if (pageType==='gameslist' ) { %>
        <title>游戏列表 | Flash收藏站</title>
        <meta name="description" content="浏览所有Flash游戏的完整列表，包括游戏ID、标题、发布日期、简介、开发者等信息。">
        <link rel="stylesheet" href="/api/common/gameslist.css">
    <% } else if (pageType === 'tags') { %>
        <title>标签列表 | Flash收藏站</title>
        <meta name="description" content="浏览所有Flash游戏标签，通过标签云和标签列表快速查找喜欢的Flash游戏。">
        <link rel="stylesheet" href="/api/common/tags.css">
    <% } else if (pageType === 'tag-games') { %>
        <title>标签：<%= tagName %> | Flash收藏站</title>
        <meta name="keywords" content="<%= tagName %>,Flash游戏标签,Flash游戏收藏站,在线小游戏">
        <meta name="description" content="此为包含标签“<%= tagName %>”的Flash游戏列表。部分游戏还附有攻略，希望你玩得高兴！">
        <link rel="stylesheet" href="/api/common/tags.css">
        <link rel="stylesheet" href="/api/common/author-games.css">
    <% } else if (pageType === 'categories') { %>
        <title>分类列表 | Flash收藏站</title>
        <meta name="description" content="浏览所有Flash游戏分类，快捷直达喜欢的游戏题材。">
        <link rel="stylesheet" href="/api/common/categories.css">
    <% } else if (pageType === 'category-games') { %>
        <title>分类：<%= catName %> | Flash收藏站</title>
        <meta name="keywords" content="<%= catName %>,Flash游戏分类,Flash游戏收藏站,在线小游戏">
        <meta name="description" content="此为分类“<%= catName %>”下的Flash游戏列表。部分游戏还附有攻略，希望你玩得高兴！">
        <link rel="stylesheet" href="/api/common/categories.css">
        <link rel="stylesheet" href="/api/common/author-games.css">
    <% } %>
    <% if (pageType === 'home') { %>
        <% let currentUrl = "https://" + domain + "/";if (typeof currentPage !== 'undefined' && currentPage > 1) {currentUrl += currentPage } %>
        <%# JSON-LD %>
        <script type="application/ld+json">
        [
            {
                "@context": "https://schema.org",
                "@type": "WebSite",
                "url": "<%= currentUrl %>",
                "name": "静水深流 | Flash收藏站",
                "description": "欢迎来到我的Flash收藏站！所有游戏人工汉化，支持在线游玩与下载。",
                "potentialAction": {
                    "@type": "SearchAction",
                    "target": "https://<%= domain %>/?search={search_term_string}",
                    "query-input": "required name=search_term_string"
                }
            },
            {
                "@context": "https://schema.org",
                "@type": "BreadcrumbList",
                "itemListElement": [
                    {
                        "@type": "ListItem",
                        "position": 1,
                        "name": "首页",
                        "item": "https://<%= domain %>/"
                    }
                ]
            }
        ]
        </script>
    <% } else if (pageType === 'game' && typeof game !== 'undefined') { %>
        <%# JSON-LD %>
        <script type="application/ld+json">
        [
            {
                "@context": "https://schema.org/",
                "@type": "SoftwareApplication",
                "name": "<%= game.title %>",
                "description": "<%= game.brief %>",
                "image": "https://<%= domain + game.cover %>",
                "applicationCategory": "GameApplication",
                "operatingSystem": "Windows, macOS, Linux",
                "softwareVersion": "Flash Player / Ruffle",
                "offers": {
                    "@type": "Offer",
                    "price": "0",
                    "priceCurrency": "CNY",
                    "availability": "https://schema.org/InStock"
                }
            },
            {
                "@context": "https://schema.org",
                "@type": "BreadcrumbList",
                "itemListElement": [
                    {
                        "@type": "ListItem",
                        "position": 1,
                        "name": "首页",
                        "item": "https://<%= domain %>/"
                    },
                    {
                        "@type": "ListItem",
                        "position": 2,
                        "name": "游戏",
                        "item": "https://<%= domain %>/Games/"
                    },
                    {
                        "@type": "ListItem",
                        "position": 3,
                        "name": "<%= game.title %>",
                        "item": "https://<%= domain %><%= game.dir %>/"
                    }
                ]
            }
        ]
        </script>
    <% } else if (pageType === 'about') { %>
        <%# JSON-LD %>
        <script type="application/ld+json">
        [
            {
                "@context": "https://schema.org",
                "@type": "AboutPage",
                "mainEntity": {
                    "@type": "Organization",
                    "name": "静水深流 Flash收藏站",
                    "description": "关于本站的统计信息与介绍",
                    "logo": "https://<%= domain %>/api/icon/H.svg",
                    "url": "https://<%= domain %>/"
                }
            },
            {
                "@context": "https://schema.org",
                "@type": "BreadcrumbList",
                "itemListElement": [
                    {
                        "@type": "ListItem",
                        "position": 1,
                        "name": "首页",
                        "item": "https://<%= domain %>/"
                    },
                    {
                        "@type": "ListItem",
                        "position": 2,
                        "name": "关于本站",
                        "item": "https://<%= domain %>/about/"
                    }
                ]
            }
        ]
        </script>
    <% } else if (pageType === 'author-games') { %>
        <%# JSON-LD %>
        <script type="application/ld+json">
        [
            {
                "@context": "https://schema.org",
                "@type": "ProfilePage",
                "mainEntity": {
                    "@type": "Person",
                    "name": "<%= personName %>",
                    "description": "<% 
                        var dynamicDesc2 = "";
                        if (personType === 'author') { 
                            dynamicDesc2 = "此为 " + personName + " 被收藏的所有作品";
                        } else { 
                            dynamicDesc2 = "此为 " + personName + " 汉化的游戏";
                        } 
                    %>
                    <%= dynamicDesc2 %>",
                    "jobTitle": "<%= personType === 'author' ? '游戏开发者' : '游戏汉化者' %>",
                    "url": "https://<%= domain %>/<%= personType === 'author' ? 'authors' : 'translators' %>/<%= personName %>/"
                }
            },
            {
                "@context": "https://schema.org",
                "@type": "BreadcrumbList",
                "itemListElement": [
                    {
                        "@type": "ListItem",
                        "position": 1,
                        "name": "首页",
                        "item": "https://<%= domain %>/"
                    },
                    {
                        "@type": "ListItem",
                        "position": 2,
                        "name": "<%= personType === 'author' ? '游戏开发者' : '汉化贡献者' %>",
                        "item": "https://<%= domain %>/<%= personType === 'author' ? 'authors' : 'translators' %>/"
                    },
                    {
                        "@type": "ListItem",
                        "position": 3,
                        "name": "<%= personName %>",
                        "item": "https://<%= domain %>/<%= personType === 'author' ? 'authors' : 'translators' %>/<%= personName %>/"
                    }
                ]
            }
        ]
        </script>
    <% } else if (pageType === 'authors' || pageType === 'translators' || pageType === 'author') { %>
        <%# JSON-LD %>
        <script type="application/ld+json">
        [
            <% if (typeof list !== 'undefined') { %>
            {
                "@context": "https://schema.org",
                "@type": "ItemList",
                "name": "<%= title %>",
                "itemListElement": [
                    <% list.forEach(function(item, idx) { %>
                    {
                        "@type": "ListItem",
                        "position": <%= idx + 1 %>,
                        "url": "https://<%= domain %>/<%= pageType === 'author' ? 'authors' : (pageType === 'translators' ? 'translators' : 'authors') %>/<%= item.name %>/",
                        "name": "<%= item.name %>"
                    }<%= idx < list.length - 1 ? ',' : '' %>
                    <% }) %>
                ]
            },
            <% } %>
            {
                "@context": "https://schema.org",
                "@type": "BreadcrumbList",
                "itemListElement": [
                    {
                        "@type": "ListItem",
                        "position": 1,
                        "name": "首页",
                        "item": "https://<%= domain %>/"
                    },
                    {
                        "@type": "ListItem",
                        "position": 2,
                        "name": "<%= pageType === 'translators' ? '汉化贡献者' : '游戏开发者' %>",
                        "item": "https://<%= domain %>/<%= pageType === 'translators' ? 'translators' : 'authors' %>/"
                    }
                ]
            }
        ]
        </script>
    <% } else if (pageType === 'friend') { %>
        <%# JSON-LD %>
        <script type="application/ld+json">
        {
            "@context": "https://schema.org",
            "@type": "BreadcrumbList",
            "itemListElement": [
                {
                    "@type": "ListItem",
                    "position": 1,
                    "name": "首页",
                    "item": "https://<%= domain %>/"
                },
                {
                    "@type": "ListItem",
                    "position": 2,
                    "name": "友情链接",
                    "item": "https://<%= domain %>/friend/"
                }
            ]
        }
        </script>
    <% } else if (pageType === 'gameslist') { %>
        <%# JSON-LD %>
        <script type="application/ld+json">
        {
            "@context": "https://schema.org",
            "@type": "BreadcrumbList",
            "itemListElement": [
                {
                    "@type": "ListItem",
                    "position": 1,
                    "name": "首页",
                    "item": "https://<%= domain %>/"
                },
                {
                    "@type": "ListItem",
                    "position": 2,
                    "name": "游戏列表",
                    "item": "https://<%= domain %>/Games/"
                }
            ]
        }
        </script>
    <% } %>
    <%# 公共JS %>
    <script type="text/javascript" src="/api/common/sitetime.js" defer></script>
    <script type="text/javascript" src="/api/common/count.js" defer></script>
    <script type="text/javascript" src="/api/common/toggle.js" defer></script>
    <script type="text/javascript" src="/api/common/search.js" defer></script>
    <!-- Google Analytics
        <script>
            window.dataLayer = window.dataLayer || [];
            function gtag(){dataLayer.push(arguments);}
            gtag('js', new Date());

            gtag('config', 'G-9C3EYEPPQ1');
        </script>
    -->
    <script src="https://analytics.hcyhub.com/tracker.js" data-site-id="FlashArchive" data-endpoint="https://analytics.hcyhub.com" defer></script>
    <%# 公共CSS %>
    <link rel="stylesheet" href="/api/icon/css/all.min.css">
    <link rel="stylesheet" href="/api/common/header.css">
    <link rel="stylesheet" href="/api/common/footer.css">
    <link rel="icon" href="/api/icon/H.svg">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="author" content="Ethaniel">
    <meta name="google-site-verification" content="mD2l3_aOmwjXLEvIAyB7bLGNGBnq7u88vPoK2oNuy3c" />
</head>